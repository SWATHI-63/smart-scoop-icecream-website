{
  "name": "franchise-analytics-module",
  "version": "1.0.0",
  "description": "Franchise Profit & Loss dashboard with expansion prediction",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:schema": "node scripts/run-sql.js schema",
    "db:seed": "node scripts/run-sql.js seed",
    "db:setup": "npm run db:schema && npm run db:seed",
    "db:docker:up": "docker compose up -d db",
    "db:docker:down": "docker compose down"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ml-regression-multivariate-linear": "^2.0.4",
    "pg": "^8.12.0"
  }
}
